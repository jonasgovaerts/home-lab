{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update image tags in argo-project.yaml or values.yaml",
      "fileMatch": [
        "kubernetes/.*/(argo-project|values)\\.ya?ml$"
      ],
      "matchStrings": [
        "repository:\\s*(?<depName>[\\w\\-/\\.]+)\\s*\\n\\s*tag:\\s*(?<currentValue>[\\w\\.\\-]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "argocd",
        "custom.regex"
      ],
      "groupName": "ArgoCD and image updates"
    }
  ]
}