{
  "extends": ["config:base"],
  "enabledManagers": ["regex"],
  "regexManagers": [
    {
      "description": "Update Helm chart versions in Flux HelmRelease",
      "fileMatch": ["kubernetes/.*/helm-release\\.ya?ml$"],
      "matchStrings": [
        "chart:\\s*\\n\\s*spec:\\s*\\n\\s*chart:\\s*(?<depName>[\\w\\-/]+)\\s*\\n\\s*version:\\s*(?<currentValue>[\\w\\.\\-]+)"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "description": "Update image tags in values.yaml or helm-release.yaml",
      "fileMatch": ["kubernetes/.*/(helm-release|values)\\.ya?ml$"],
      "matchStrings": [
        "repository:\\s*(?<depName>[\\w\\-/\\.]+)\\s*\\n\\s*tag:\\s*(?<currentValue>[\\w\\.\\-]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["regex"],
      "groupName": "Flux Helm and image updates"
    }
  ]
}

